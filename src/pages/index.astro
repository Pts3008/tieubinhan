---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const reviews = [
  {
    slug: "pham-nhan-tu-tien",
    title: "Phàm Nhân Tu Tiên",
    author: "Vong Ngữ",
    genre: "Tiên hiệp",
    chapters: 3465,
    score: 9.1,
    excerpt: "Một trong những bộ tiên hiệp kinh điển nhất — nhân vật chính không thiên tài, không may mắn, chỉ có sự nỗ lực và tư duy chiến lược khiến người đọc không thể dừng.",
    tags: ["Tiên hiệp", "Kinh điển"],
    badge: "Đỉnh niche",
  },
  {
    slug: "dau-la-dai-luc",
    title: "Đấu La Đại Lục",
    author: "Đường Gia Tam Thiếu",
    genre: "Kiếm hiệp",
    chapters: 396,
    score: 8.5,
    excerpt: "Thế giới không có pháp thuật, chỉ có võ hồn. Đường Tam tái sinh với ký ức kiếp trước, xây dựng đội hình cực kỳ ăn ý và hệ thống chiến đấu độc đáo.",
    tags: ["Kiếm hiệp", "Tái sinh"],
    badge: null,
  },
  {
    slug: "tien-nghich",
    title: "Tiên Nghịch",
    author: "Nhĩ Căn",
    genre: "Tiên hiệp",
    chapters: 1878,
    score: 8.8,
    excerpt: "Vương Lâm — nhân vật phản diện trong mắt người khác nhưng chính nghĩa trong góc nhìn của mình. Chiều sâu nhân vật thuộc hàng tốt nhất thể loại.",
    tags: ["Tiên hiệp", "Nhĩ Căn"],
    badge: null,
  },
];

const topList = [
  { title: "Phàm Nhân Tu Tiên", score: 9.1, views: "8.4K" },
  { title: "Tiên Nghịch", score: 8.8, views: "6.1K" },
  { title: "Đấu La Đại Lục", score: 8.5, views: "5.7K" },
  { title: "Đấu Phá Thương Khung", score: 8.2, views: "4.2K" },
];
---

<Layout title="Trang chủ" description="Review truyện kiếm hiệp, tiên hiệp hay nhất Việt Nam">

  <!-- Hero bài nổi bật -->
  <div class="bg-white border border-gray-200 rounded-xl p-5 mb-6">
    <span class="text-xs font-semibold text-indigo-500 uppercase tracking-wider">Review nổi bật</span>
    <h1 class="text-xl font-semibold mt-1 mb-2">
      Đấu Phá Thương Khung — có thật sự xứng đáng với danh tiếng?
    </h1>
    <div class="flex items-center gap-3 mb-3">
      <div class="flex text-yellow-500 text-sm">★★★★☆</div>
      <span class="bg-amber-100 text-amber-800 text-xs font-medium px-2 py-0.5 rounded-full">8.2 / 10</span>
      <span class="text-xs text-gray-400">👁 4.2K lượt đọc · ⏱ 5 phút đọc</span>
    </div>
    <p class="text-sm text-gray-500 leading-relaxed">
      Thiên Tài Đẩu Khí xuất thân từ gia tộc Tiêu, sau biến cố trở thành phế vật.
      Hành trình phục thù và trỗi dậy của Tiêu Viêm là câu chuyện cổ điển nhưng
      được Thiên Tằm Thổ Đậu xây dựng với nhịp độ cuốn hút khó có bộ nào sánh kịp.
    </p>
    <div class="flex gap-2 mt-3 flex-wrap">
      {["Tiên hiệp", "Hệ thống luyện đan", "Phục thù"].map(tag => (
        <span class="text-xs bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full font-medium">{tag}</span>
      ))}
    </div>
    <a href="/review/dau-pha-thuong-khung" class="inline-block mt-4 text-sm font-medium text-indigo-500 hover:underline">
      Đọc review đầy đủ →
    </a>
  </div>

  <!-- 2 cột: danh sách + sidebar -->
  <div class="grid grid-cols-1 md:grid-cols-[1fr_220px] gap-6">

    <!-- Danh sách review -->
    <div>
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Bài review mới nhất</p>
      <div class="flex flex-col gap-3">
        {reviews.map(r => (
          <a href={`/review/${r.slug}`} class="bg-white border border-gray-200 rounded-xl p-4 flex gap-3 hover:border-gray-300 transition-colors">
            <!-- Cover placeholder -->
            <div class="w-12 h-16 rounded bg-indigo-50 flex items-center justify-center flex-shrink-0 text-xl">
              ⚔️
            </div>
            <div class="min-w-0">
              <div class="font-medium text-sm text-gray-800">{r.title}</div>
              <div class="text-xs text-gray-400 mb-1">{r.author} · {r.genre} · {r.chapters} chương</div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-yellow-500 text-xs">{"★".repeat(Math.round(r.score/2))}{"☆".repeat(5 - Math.round(r.score/2))}</span>
                <span class="text-xs font-semibold text-amber-700">{r.score}</span>
                {r.badge && <span class="text-xs bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full font-medium">{r.badge}</span>}
              </div>
              <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">{r.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Sidebar -->
    <div>
      <!-- AdSense placeholder -->
      <div class="border border-dashed border-gray-300 rounded-xl p-4 text-center mb-5">
        <p class="text-xs text-gray-400">Google AdSense</p>
        <p class="text-xs text-gray-300">160 × 300</p>
      </div>

      <!-- Top truyện -->
      <div class="bg-white border border-gray-200 rounded-xl p-4 mb-4">
        <p class="text-xs font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-100">Top review cao nhất</p>
        {topList.map((item, i) => (
          <div class="flex items-center gap-2 mb-2 last:mb-0">
            <span class="text-sm font-semibold text-indigo-400 w-4">{i + 1}</span>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-medium text-gray-800 truncate">{item.title}</p>
              <p class="text-xs text-gray-400">{item.score} · {item.views} lượt xem</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Thể loại -->
      <div class="bg-white border border-gray-200 rounded-xl p-4">
        <p class="text-xs font-semibold text-gray-800 mb-3 pb-2 border-b border-gray-100">Thể loại</p>
        {[
          ["Tiên hiệp", 42], ["Kiếm hiệp", 31], ["Huyền huyễn", 18],
          ["Có hệ thống", 15], ["Đô thị tu tiên", 9], ["Top list", 24]
        ].map(([name, count]) => (
          <a href={`/the-loai/${name}`} class="flex justify-between items-center py-1 text-xs text-gray-500 hover:text-gray-800">
            <span>{name}</span>
            <span class="bg-gray-100 px-2 py-0.5 rounded-full">{count}</span>
          </a>
        ))}
      </div>
    </div>

  </div>
</Layout>